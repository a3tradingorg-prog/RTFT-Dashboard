# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SUPABASE_URL: Your Supabase project URL
VITE_SUPABASE_URL=""
# VITE_SUPABASE_ANON_KEY: Your Supabase anonymous API key
VITE_SUPABASE_ANON_KEY=""
# DATABASE_URL / SUPABASE_DB_URL: Connection URI for one-click SQL Admin Auto-Setup (e.g., postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres)
DATABASE_URL=""

# VITE_ALPHA_VANTAGE_API_KEY: Required for Alpha Vantage Earnings Calendar API
VITE_ALPHA_VANTAGE_API_KEY=""

# VITE_FINNHUB_API_KEY: Required for Finnhub API (Economic Calendar & Logos)
VITE_FINNHUB_API_KEY=""

# GEMINI_API_KEY: Server-side API key for AI Trader Insights analysis
GEMINI_API_KEY=""
